# TEMPORARY — React 17 + @carbon/react@^1.15 peer-dep graph requires this to
# install cleanly. Removed in #3452 (pnpm migration, M1.f of epic #3449),
# which enforces strict peer resolution via pnpm's content-addressable store.
legacy-peer-deps=true

# Plain `npm ci` can look "stuck" for minutes while Cypress and peers unpack.
# Progress + notice-level lifecycle keeps the terminal visibly active.
progress=true
loglevel=notice
