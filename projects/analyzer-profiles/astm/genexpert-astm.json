{
  "$schema": "https://openelis-global.org/schemas/analyzer-defaults/1.0",
  "profileMeta": {
    "id": "genexpert-astm",
    "version": "1.2.0",
    "displayName": "Cepheid GeneXpert (ASTM Mode)"
  },
  "analyzer_name": "Cepheid GeneXpert (ASTM Mode)",
  "manufacturer": "Cepheid",
  "category": "MOLECULAR",
  "protocol": { "name": "ASTM", "version": "E-1394-97" },
  "identifier_pattern": "GENEXPERT|CEPHEID",
  "transport": ["RS-232", "TCP/IP"],
  "transport_config": {
    "RS-232": { "default_baud_rate": 9600 },
    "TCP/IP": {}
  },
  "communication": {
    "mode": "ANALYZER_INITIATED",
    "supports_lis_initiated": false,
    "notes": "ASTM E1394: analyzer connects to bridge TCP server and sends R-segments (results) or Q-segments (queries). OE responds in-session via AnalyzerResponder. All communication is analyzer-initiated."
  },
  "default_test_mappings": [
    {
      "test_code": "MTB-RIF",
      "test_name_hint": "Mycobacterium tuberculosis DNA",
      "loinc": "23826-1",
      "unit": ""
    },
    {
      "test_code": "RIF",
      "test_name_hint": "Rifampin Resistance",
      "loinc": "46244-0",
      "unit": ""
    },
    {
      "test_code": "COVID19",
      "test_name_hint": "SARS-CoV-2 RNA",
      "loinc": "94500-6",
      "unit": ""
    },
    {
      "test_code": "HIV-VL",
      "test_name_hint": "HIV-1 RNA",
      "loinc": "20447-9",
      "unit": "copies/mL"
    }
  ],
  "configDefaults": {
    "connectionRole": "SERVER",
    "aggregationMode": "PER_MESSAGE",
    "qcRules": [],
    "extractionOverrides": {},
    "flagMappings": {},
    "transforms": {}
  },
  "notes": "Multi-protocol capable: FILE (primary), ASTM, HL7 all confirmed per Cepheid LIS spec. This config is for ASTM mode. Results are typically qualitative (Detected/Not Detected) for most assays. GeneXpert supports both RS-232 and TCP/IP transports."
}
