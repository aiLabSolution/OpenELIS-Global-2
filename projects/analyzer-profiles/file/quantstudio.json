    "Quantity Mean": "result",
    "CT": "ctValue",
    "Well Position": "position",
    "Task": "qcTask",
    "Quantity": "quantityRaw",
    "Ct Mean": "ctMean",
    "Comments": "comments"
  },
  "column_spec": {
    "reference": "quantstudio-field-mapping-spec-v131",
    "core_columns": [
      "Well",
      "Well Position",
      "Omit",
      "Sample Name",
      "Target Name",
      "Task",
      "Reporter",
      "Quencher",
      "CT",
      "Ct Mean",
      "Ct SD",
      "Quantity",
      "Quantity Mean",
      "Quantity SD",
      "Automatic Ct Threshold",
      "Ct Threshold",
