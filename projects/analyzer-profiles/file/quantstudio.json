    "optional_columns": [
      "NOAMP",
      "EXPFAIL",
      "THOLDFAIL",
      "HIGHSD",
      "PRFLOW",
      "CQCONF",
      "Amp Score",
      "Y-Intercept",
      "R\u00b2",
      "Slope",
      "Efficiency"
