{
  "$schema": "https://openelis-global.org/schemas/analyzer-defaults/1.0",
  "profileMeta": {
    "id": "dtprime",
    "version": "1.0.0",
    "displayName": "DNA Technology DT-Prime",
    "confidence": "MEDIUM",
    "manufacturer": "DNA Technology"
  },
  "protocol": {
    "name": "FILE",
    "format": "XML"
  },
  "category": "MOLECULAR",
  "supported_extensions": [
    ".xml"
  ],
  "column_mapping": {
    "SampleID": "sampleId",
    "WellPosition": "position",
    "Result": "result",
    "Interpretation": "interpretation"
  },
  "xml_schema": {
    "encoding": "windows-1251",
    "root": "package",
    "xpath": {
      "plate": "/package/data/plate",
      "cell": "cell",
      "cell_name": "@name",
      "cell_x": "@x",
      "cell_y": "@y",
      "cell_state": "@state",
      "test_value": "test/@value",
      "result_value": "test/result/@value"
    },
    "result_values": {
      "+": "Detected",
      "-": "Not Detected"
    },
    "qc_patterns": {
      "negative_control": "C-",
      "positive_control": "C+"
    }
  },
  "configDefaults": {
    "fileFormat": "XML",
    "qcRules": [
      {
        "ruleType": "SPECIMEN_ID_PREFIX",
        "operand": "C+",
        "isActive": true,
        "sortOrder": 1
      },
      {
        "ruleType": "SPECIMEN_ID_PREFIX",
        "operand": "C-",
        "isActive": true,
        "sortOrder": 2
      },
      {
        "ruleType": "SPECIMEN_ID_PREFIX",
        "operand": "NTC",
        "isActive": true,
        "sortOrder": 3
      },
      {
        "ruleType": "SPECIMEN_ID_PREFIX",
        "operand": "PTC",
        "isActive": true,
        "sortOrder": 4
      }
    ]
  }
}
