{
  "$schema": "https://openelis-global.org/schemas/analyzer-defaults/1.0",
  "profileMeta": {
    "id": "seamaty-sd1",
    "version": "1.0.0",
    "displayName": "Seamaty SD1",
    "confidence": "MEDIUM_HIGH",
    "status": "READY"
  },
  "analyzer_name": "Seamaty SD1",
  "manufacturer": "Seamaty",
  "category": "CHEMISTRY",
  "protocol": {
    "name": "HL7",
    "version": "2.3.1"
  },
  "identifier_pattern": "SMT|SD1|SEAMATY",
  "transport": [
    "TCP/IP"
  ],
  "transport_config": {
    "TCP/IP": {
      "framing": "MLLP"
    }
  },
  "communication": {
    "mode": "ANALYZER_INITIATED",
    "supports_lis_initiated": false,
    "notes": "Upload-only ORU^R01 over MLLP. SD1 MSH-16 dispatches result type: 0=patient, 1=calibration, 2=QC."
  },
  "msh3_pattern": "SMT",
  "default_test_mappings": [
    {
      "test_code": "GLU",
      "test_name_hint": "Glucose",
      "loinc": "2345-7",
      "unit": "mg/dL"
    },
    {
      "test_code": "BUN",
      "test_name_hint": "Urea Nitrogen",
      "loinc": "3094-0",
      "unit": "mg/dL"
    },
    {
      "test_code": "CREA",
      "test_name_hint": "Creatinine",
      "loinc": "2160-0",
      "unit": "mg/dL"
    },
    {
      "test_code": "AST",
      "test_name_hint": "Aspartate Aminotransferase",
      "loinc": "1920-8",
      "unit": "U/L"
    },
    {
      "test_code": "ALT",
      "test_name_hint": "Alanine Aminotransferase",
      "loinc": "1742-6",
      "unit": "U/L"
    },
    {
      "test_code": "TP",
      "test_name_hint": "Total Protein",
      "loinc": "2885-2",
      "unit": "g/dL"
    }
  ],
  "configDefaults": {
    "qcRules": [
      {
        "ruleType": "FIELD_EQUALS",
        "targetField": "MSH.16",
        "operand": "2",
        "isActive": true,
        "sortOrder": 1
      }
    ]
  },
  "notes": "Profile for the SD1 dry-chemistry HL7 bench path. Bridge code treats MSH-16=1 calibration as a separate non-patient path and MSH-16=2 as QC; OBR-14 carries lot number and OBR-20 carries QC type/level when present."
}
