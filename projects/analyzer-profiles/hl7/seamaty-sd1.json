  "transport": [
    "TCP/IP"
  ],
  "transport_config": {
    "TCP/IP": {
      "default_port": 2575,
      "framing": "MLLP"
    }
  },
  "communication": {
    "mode": "ANALYZER_INITIATED",
    "supports_lis_initiated": false,
    "notes": "Live SD1 bench upload sends ORU^R01 over MLLP with MSH-3=SMT and MSH-4=SD1. OpenELIS matches the instrument by ^SMT-SD1$ and pushes code-to-LOINC mappings during bridge registration. SD1 MSH-16 dispatches result type: 0=patient, 1=calibration, 2=QC."
  },
  "msh3_pattern": "SMT",
  "msh4_pattern": "SD1",
