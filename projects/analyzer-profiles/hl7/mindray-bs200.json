{
  "$schema": "https://openelis-global.org/schemas/analyzer-defaults/1.0",
  "profileMeta": {
    "id": "mindray-bs200",
    "version": "1.0.0",
    "displayName": "Mindray BS-200"
  },
  "analyzer_name": "Mindray BS-200",
  "manufacturer": "Mindray",
  "category": "CHEMISTRY",
  "protocol": { "name": "HL7", "version": "2.3.1" },
  "identifier_pattern": "MINDRAY.*BS.?200|BS200",
  "transport": ["TCP/IP"],
  "transport_config": {
    "TCP/IP": { "default_port": 6001, "framing": "MLLP" }
  },
  "communication": {
    "mode": "ANALYZER_INITIATED",
    "supports_lis_initiated": true,
    "notes": "HL7 push (ORU^R01) via MLLP. Bidirectional QRY^Q02/DSR^Q03 documented in vendor manual but not yet implemented in OE (OGC-326)."
  },
  "msh3_pattern": "MINDRAY",
  "default_test_mappings": [
    {
      "test_code": "GLU",
      "test_name_hint": "Glucose",
      "loinc": "2345-7",
      "unit": "mg/dL"
    },
    {
      "test_code": "CREA",
      "test_name_hint": "Creatinine",
      "loinc": "2160-0",
      "unit": "mg/dL"
    },
    {
      "test_code": "ALT",
      "test_name_hint": "Alanine Aminotransferase",
      "loinc": "1742-6",
      "unit": "U/L"
    },
    {
      "test_code": "AST",
      "test_name_hint": "Aspartate Aminotransferase",
      "loinc": "1920-8",
      "unit": "U/L"
    },
    {
      "test_code": "ALB",
      "test_name_hint": "Albumin",
      "loinc": "1751-7",
      "unit": "g/dL"
    },
    {
      "test_code": "TP",
      "test_name_hint": "Total Protein",
      "loinc": "2885-2",
      "unit": "g/dL"
    },
    {
      "test_code": "TBIL",
      "test_name_hint": "Total Bilirubin",
      "loinc": "1975-2",
      "unit": "mg/dL"
    },
    {
      "test_code": "UREA",
      "test_name_hint": "Blood Urea Nitrogen",
      "loinc": "3094-0",
      "unit": "mg/dL"
    }
  ],
  "configDefaults": {},
  "notes": "Semi-automatic chemistry analyzer. Same HL7 v2.3.1 interface as BS-360E. Requires MLLP framing. MSH-3 typically identifies the manufacturer (e.g. 'MINDRAY' per msh3_pattern); exact sender value must be confirmed per deployment."
}
