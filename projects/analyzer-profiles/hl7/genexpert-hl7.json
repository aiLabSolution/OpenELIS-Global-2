{
  "$schema": "https://openelis-global.org/schemas/analyzer-defaults/1.0",
  "profileMeta": {
    "id": "genexpert-hl7",
    "version": "1.2.0",
    "displayName": "Cepheid GeneXpert (HL7 Mode)"
  },
  "analyzer_name": "Cepheid GeneXpert (HL7 Mode)",
  "manufacturer": "Cepheid",
  "category": "MOLECULAR",
  "protocol": { "name": "HL7", "version": "2.5" },
  "identifier_pattern": "GENEXPERT|CEPHEID",
  "transport": ["HTTP", "TCP/IP"],
  "transport_config": {
    "HTTP": { "default_port": 8080 },
    "TCP/IP": {}
  },
  "communication": {
    "mode": "ANALYZER_INITIATED",
    "supports_lis_initiated": true,
    "notes": "HL7 push (ORU^R01) + query (QBP^Z01/Z03) per Cepheid LIS spec. Analyzer initiates all connections in current OE implementation. Bidirectional QBP support documented but not yet LIS-initiated (OGC-336)."
  },
  "msh3_pattern": "GENEXPERT|CEPHEID",
  "default_test_mappings": [
    {
      "test_code": "MTB",
      "test_name_hint": "Mycobacterium tuberculosis DNA",
      "loinc": "23826-1",
      "unit": ""
    },
    {
      "test_code": "RIF",
      "test_name_hint": "Rifampin Resistance",
      "loinc": "46244-0",
      "unit": ""
    },
    {
      "test_code": "COVID19",
      "test_name_hint": "SARS-CoV-2 RNA",
      "loinc": "94500-6",
      "unit": ""
    },
    {
      "test_code": "HIV",
      "test_name_hint": "HIV-1 RNA",
      "loinc": "20447-9",
      "unit": "copies/mL"
    }
  ],
  "configDefaults": {},
  "notes": "Multi-protocol capable: FILE (primary), ASTM, HL7 all confirmed per Cepheid LIS spec. This config is for HL7 mode via HTTP transport. GeneXpert uses HTTP instead of MLLP framing. MSH-3 sending application = 'GENEXPERT' or 'CEPHEID'. Results are qualitative (Detected/Not Detected) for most assays."
}
