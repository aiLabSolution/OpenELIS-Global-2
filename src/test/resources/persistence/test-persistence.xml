<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="http://xmlns.jcp.org/xml/ns/persistence"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/persistence http://xmlns.jcp.org/xml/ns/persistence/persistence_2_2.xsd"
    version="2.2">

    <persistence-unit
        name="OpenELIS-Global-persistence-unit"
        exclude-unlisted-classes="true">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <!-- converters -->
        <class>org.itech.fhir.dataexport.core.model.converter.DataExportStatusConverter</class>
        <class>org.itech.fhir.dataexport.core.model.converter.FhirResourceTypeConverter</class>
        <class>org.openelisglobal.hibernate.converter.URIConverter</class>
        <class>org.openelisglobal.security.converter.EncryptionConverter</class>

        <!-- entities -->
        <class>org.openelisglobal.localization.valueholder.Localization</class>
        <class>org.openelisglobal.localization.valueholder.LocalizationValue</class>
        <class>org.openelisglobal.localization.valueholder.SupportedLocale</class>
        <class>org.openelisglobal.testcalculated.valueholder.Operation</class>
        <class>org.openelisglobal.analysis.valueholder.ResultFile</class>
        <class>org.openelisglobal.testcalculated.valueholder.ResultCalculation</class>
        <class>org.openelisglobal.testcalculated.valueholder.Calculation</class>
        <class>org.openelisglobal.testreflex.action.bean.ReflexRuleOptionsDisplayItem</class>
        <class>org.openelisglobal.testreflex.action.bean.ReflexRuleAction</class>
        <class>org.openelisglobal.testreflex.action.bean.ReflexRuleOptions</class>
        <class>org.openelisglobal.testreflex.action.bean.ReflexRuleCondition</class>
        <class>org.openelisglobal.testreflex.action.bean.ReflexRule</class>
        <class>org.openelisglobal.testreflex.valueholder.TestReflex</class>
        <class>org.openelisglobal.analyzer.valueholder.AnalyzerExperiment</class>
        <class>org.openelisglobal.login.valueholder.LoginUser</class>
        <class>org.openelisglobal.gender.valueholder.Gender</class>
        <class>org.openelisglobal.externalconnections.valueholder.ExternalConnection</class>
        <class>org.openelisglobal.externalconnections.valueholder.ExternalConnectionContact</class>
        <class>org.openelisglobal.externalconnections.valueholder.CertificateAuthenticationData</class>
        <class>org.openelisglobal.externalconnections.valueholder.BasicAuthenticationData</class>
        <class>org.openelisglobal.testresultsview.valueholder.ClientResultsViewBean</class>
        <class>org.openelisglobal.projectorganization.valueholder.ProjectOrganization</class>

        <class>org.itech.fhir.dataexport.core.model.DataExportAttempt</class>
        <class>org.itech.fhir.dataexport.core.model.DataExportTask</class>

        <class>org.ozeki.sms.valueholder.OzekiMessageOut</class>


        <class>org.openelisglobal.program.valueholder.ProgramSample</class>
        <class>org.openelisglobal.program.valueholder.cytology.CytologySample</class>
        <class>org.openelisglobal.program.valueholder.cytology.CytologyDiagnosis</class>
        <class>org.openelisglobal.program.valueholder.cytology.CytologySpecimenAdequacy</class>
        <class>org.openelisglobal.program.valueholder.cytology.CytologyReport</class>
        <class>org.openelisglobal.program.valueholder.cytology.CytologySlide</class>
        <class>org.openelisglobal.program.valueholder.cytology.CytologyDiagnosisCategoryResultsMap</class>


        <class>org.openelisglobal.program.valueholder.pathology.PathologySample</class>
        <class>org.openelisglobal.program.valueholder.pathology.PathologyTechnique</class>
        <class>org.openelisglobal.program.valueholder.pathology.PathologySlide</class>
        <class>org.openelisglobal.program.valueholder.pathology.PathologyRequest</class>
        <class>org.openelisglobal.program.valueholder.pathology.PathologyReport</class>
        <class>org.openelisglobal.program.valueholder.pathology.PathologyConclusion</class>
        <class>org.openelisglobal.program.valueholder.pathology.PathologyBlock</class>

        <!-- Sample Storage Management entities (001-sample-storage) - annotation-based -->
        <class>org.openelisglobal.storage.valueholder.StorageRoom</class>
        <class>org.openelisglobal.storage.valueholder.StorageDevice</class>
        <class>org.openelisglobal.storage.valueholder.StorageShelf</class>
        <class>org.openelisglobal.storage.valueholder.StorageRack</class>
        <class>org.openelisglobal.storage.valueholder.StorageBox</class>
        <class>org.openelisglobal.storage.valueholder.SampleStorageAssignment</class>
        <class>org.openelisglobal.storage.valueholder.SampleStorageMovement</class>

        <!-- Cold Storage/Freezer Monitoring entities -->
        <class>org.openelisglobal.coldstorage.valueholder.Freezer</class>
        <class>org.openelisglobal.coldstorage.valueholder.FreezerReading</class>
        <class>org.openelisglobal.coldstorage.valueholder.ThresholdProfile</class>
        <class>org.openelisglobal.coldstorage.valueholder.FreezerThresholdProfile</class>

        <!-- Alert entities -->
        <class>org.openelisglobal.alert.valueholder.Alert</class>
        <class>org.openelisglobal.coldstorage.valueholder.CorrectiveAction</class>

        <!-- Notification entities -->
        <class>org.openelisglobal.notification.valueholder.NotificationConfigOption</class>
        <class>org.openelisglobal.notification.valueholder.NotificationPayloadTemplate</class>

        <!-- Dictionary entities (required by NoteBook.type relationship) -->
        <class>org.openelisglobal.dictionary.valueholder.Dictionary</class>
        <class>org.openelisglobal.dictionarycategory.valueholder.DictionaryCategory</class>

        <!-- Notebook Management entities -->
        <class>org.openelisglobal.notebook.valueholder.NoteBook</class>
        <class>org.openelisglobal.notebook.valueholder.NoteBookPage</class>
        <class>org.openelisglobal.notebook.valueholder.NoteBookFile</class>
        <class>org.openelisglobal.notebook.valueholder.NoteBookComment</class>
        <class>org.openelisglobal.notebook.valueholder.NoteBookSample</class>

        <!-- Inventory Management entities (004-remove-old-inventory) -->
        <class>org.openelisglobal.inventory.valueholder.InventoryItem</class>
        <class>org.openelisglobal.inventory.valueholder.InventoryStorageLocation</class>
        <class>org.openelisglobal.inventory.valueholder.InventoryLot</class>
        <class>org.openelisglobal.inventory.valueholder.InventoryTransaction</class>
        <class>org.openelisglobal.inventory.valueholder.InventoryUsage</class>

        <!-- Shipment Management entities (OGC-62) -->
        <class>org.openelisglobal.shipment.valueholder.ShippingBox</class>
        <class>org.openelisglobal.shipment.valueholder.Shipment</class>
        <class>org.openelisglobal.shipment.valueholder.BoxSampleItem</class>

        <!-- ASTM Analyzer Field Mapping entities (004-astm-analyzer-mapping) -->
        <!-- All analyzer entities use JPA annotations -->
        <class>org.openelisglobal.analyzer.valueholder.Analyzer</class>
        <class>org.openelisglobal.analyzer.valueholder.AnalyzerField</class>
        <!-- AnalyzerConfiguration removed: merged into Analyzer entity -->
        <class>org.openelisglobal.analyzer.valueholder.AnalyzerError</class>
        <class>org.openelisglobal.analyzer.valueholder.AnalyzerFileUpload</class>
        <class>org.openelisglobal.analyzer.valueholder.AnalyzerRun</class>
        <class>org.openelisglobal.analyzer.valueholder.CustomFieldType</class>
        <class>org.openelisglobal.analyzer.valueholder.AnalyzerFieldMapping</class>
        <class>org.openelisglobal.analyzer.valueholder.AnalyzerPluginConfig</class>
        <class>org.openelisglobal.analyzer.valueholder.AnalyzerPendingCode</class>
        <class>org.openelisglobal.analyzer.valueholder.QualitativeResultMapping</class>
        <class>org.openelisglobal.analyzer.valueholder.UnitMapping</class>
        <class>org.openelisglobal.analyzer.valueholder.ValidationRuleConfiguration</class>
        <class>org.openelisglobal.analyzer.valueholder.FileImportConfiguration</class>
        <class>org.openelisglobal.analyzerresults.valueholder.AnalyzerResults</class>
        <class>org.openelisglobal.analyzerimport.valueholder.AnalyzerTestMapping</class>
        <class>org.openelisglobal.analyzer.valueholder.AnalyzerType</class>

        <!-- RS232 Serial Port Configuration entity (011-madagascar-analyzer-integration
            M2) -->
        <class>org.openelisglobal.analyzer.valueholder.SerialPortConfiguration</class>

        <!-- Patient Merge Backend entities (008-patient-merge-backend) -->
        <class>org.openelisglobal.patient.merge.valueholder.PatientMergeAudit</class>

        <!-- Site Branding entity (001-site-branding) -->
        <class>org.openelisglobal.sitebranding.valueholder.SiteBranding</class>
        <!-- Generic Reporting Framework entities (reporting-framework) -->
        <class>org.openelisglobal.reportdefinition.valueholder.ReportDefinition</class>

        <!-- User Role entities (Required for real UserService filtering) -->
        <class>org.openelisglobal.userrole.valueholder.UserLabUnitRoles</class>
        <class>org.openelisglobal.userrole.valueholder.LabUnitRoleMap</class>

        <!-- EQA entities -->
        <class>org.openelisglobal.eqa.valueholder.EQAProgram</class>
        <class>org.openelisglobal.eqa.valueholder.SampleEQA</class>
        <class>org.openelisglobal.eqa.valueholder.EQADistribution</class>
        <class>org.openelisglobal.eqa.valueholder.EQALabEnrollmentLabUnit</class>
        <class>org.openelisglobal.eqa.valueholder.EQALabEnrollmentTestMap</class>
        <class>org.openelisglobal.eqa.valueholder.EQALabProgramEnrollment</class>
        <class>org.openelisglobal.eqa.valueholder.EQAProgramEnrollment</class>
        <class>org.openelisglobal.eqa.valueholder.EQAProgramTest</class>
        <class>org.openelisglobal.eqa.valueholder.EQAResult</class>

        <!-- Electronic Signature entities (21 CFR Part 11) -->
        <class>org.openelisglobal.esig.valueholder.ElectronicSignature</class>
        <class>org.openelisglobal.esig.valueholder.EsigFirstUseCertification</class>

        <properties>
            <property name="hibernate.ejb.cfgfile"
                value="hibernate/test-hibernate.cfg.xml" />
            <property name="hibernate.search.backend.directory.type"
                value="local-heap" />
            <property
                name="hibernate.search.backend.analysis.configurer"
                value="class:org.openelisglobal.hibernate.search.analysis.CustomLuceneAnalysisConfigurer" />
            <property name="hibernate.hbm2ddl.auto" value="update" />
            <property
                name="jakarta.persistence.schema-generation.database.action"
                value="update" />
        </properties>

    </persistence-unit>
</persistence>
