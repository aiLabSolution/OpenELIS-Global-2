      </sqlCheck>
    </preConditions>
    <comment>Add top-level EQA parent menu item</comment>
    <insert tableName="menu" schemaName="clinlims">
      <column name="id" valueSequenceNext="menu_seq"/>
      <column name="presentation_order" value="35"/>
      <column name="element_id" value="menu_eqa"/>
      <column name="display_key" value="banner.menu.eqa"/>
      <column name="tool_tip_key" value="banner.menu.eqa.tooltip"/>
      <column name="new_window" valueBoolean="false"/>
      <column name="is_active" valueBoolean="true"/>
      <column name="hide_in_old_ui" valueBoolean="true"/>
