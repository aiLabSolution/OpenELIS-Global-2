  </changeSet>

  <!-- ============================================================ -->
  <!-- 9. Update alert_type CHECK constraint to include EQA types   -->
  <!-- ============================================================ -->
  <changeSet id="eqa-007-11" author="eqa-module">
    <preConditions onFail="MARK_RAN">
      <tableExists schemaName="clinlims" tableName="alert"/>
    </preConditions>
    <comment>Update alert_type CHECK constraint to include EQA/QC alert types</comment>
    <sql>
      ALTER TABLE clinlims.alert DROP CONSTRAINT IF EXISTS chk_alert_type;
      ALTER TABLE clinlims.alert ADD CONSTRAINT chk_alert_type
      CHECK (alert_type IN (
        'FREEZER_TEMPERATURE', 'EQUIPMENT_FAILURE', 'INVENTORY_LOW', 'SAMPLE_TRACKING', 'OTHER',
        'EQA_DEADLINE', 'SAMPLE_EXPIRATION', 'STAT_UPCOMING', 'STAT_OVERDUE', 'CRITICAL_UNACKNOWLEDGED'
      ));
    </sql>
  </changeSet>

</databaseChangeLog>
