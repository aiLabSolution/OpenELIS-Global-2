        <insert tableName="menu" schemaName="clinlims">
            <column name="id" valueSequenceNext="menu_seq"/>
            <column name="parent_id" valueComputed="(SELECT id FROM clinlims.menu WHERE element_id = 'menu_order_workflow')"/>
            <column name="presentation_order" valueNumeric="0"/>
            <column name="element_id" value="menu_order_dashboard"/>
            <column name="action_url" value="/order"/>
