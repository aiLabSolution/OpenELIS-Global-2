<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet author="mosesmutesasira" id="EQA-001-2026-03-17-1">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">select count(*) from clinlims.site_information where name = 'eqaEnabled';</sqlCheck>
        </preConditions>
        <comment>Add EQA enabled configuration to site_information (Order Entry Config)</comment>
        <insert schemaName="clinlims" tableName="site_information">
            <column name="id" valueSequenceNext="site_information_seq" />
            <column name="name" value="eqaEnabled" />
            <column name="lastupdated" valueComputed="${now}" />
            <column name="description" value="If true, the EQA checkbox appears on Order Entry allowing a sample to be marked as an EQA sample" />
            <column name="value" value="false" />
            <column name="encrypted" value="false" />
            <column name="domain_id" valueComputed="(SELECT id FROM site_information_domain WHERE name = 'sampleEntryConfig')" />
            <column name="value_type" value="boolean" />
            <column name="instruction_key" value="instructions.order.entry.eqa.enabled" />
            <column name="group" value="0" />
        </insert>
    </changeSet>

</databaseChangeLog>
