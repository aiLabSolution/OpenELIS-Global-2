<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="20260408-001" author="reagan-meant">
        <preConditions onFail="MARK_RAN">
            <not>
                <sequenceExists sequenceName="site_code_seq" schemaName="clinlims"/>
            </not>
        </preConditions>
        <comment>Create sequence for auto-generating sampling site codes</comment>
        <createSequence sequenceName="site_code_seq" schemaName="clinlims"
                        startValue="1" incrementBy="1"/>
        <rollback>
            <dropSequence sequenceName="site_code_seq" schemaName="clinlims"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
