<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <!--
    OGC-949 M16 / OGC-763 — Alerts: per-test alert rule authoring.
    Per the v2.5 epic restructure (NOT the FRS v2.4 SQL):
      * 5 trigger types incl. COMPLIANCE_BREACH (ENV/VECTOR)
      * per-rule acknowledgment_required (OGC-997, FRS D-05)
      * NO message templates — delivery + templates live in the shipped
        Notification system; this table only authors the rule + recipients.
    -->

    <changeSet id="OGC-763-test-alert-rule-table" author="OGC">
        <createTable schemaName="clinlims" tableName="test_alert_rule">
            <column name="id" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false" primaryKeyName="pk_test_alert_rule"/>
            </column>
            <column name="test_id" type="numeric(10)">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="is_enabled" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="trigger_type" type="VARCHAR(30)">
                <constraints nullable="false"/>
            </column>
            <column name="trigger_value" type="VARCHAR(100)"/>
            <column name="notify_sms" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="notify_email" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="notify_ordering_physician" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="notify_patient" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="notify_referring_facility" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="notify_custom_phone" type="VARCHAR(20)"/>
            <column name="notify_custom_email" type="VARCHAR(100)"/>
            <column name="notify_role_id" type="numeric(10)"/>
            <column name="acknowledgment_required" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="lastupdated" type="TIMESTAMP" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <!-- BaseObject @Version maps to last_updated -->
            <column name="last_updated" type="TIMESTAMP"/>
        </createTable>

        <sql>
            ALTER TABLE clinlims.test_alert_rule
            ADD CONSTRAINT test_alert_rule_trigger_chk
            CHECK (trigger_type IN ('ALL', 'ABNORMAL', 'CRITICAL', 'SPECIFIC_VALUE', 'COMPLIANCE_BREACH'))
        </sql>

        <addForeignKeyConstraint
            constraintName="fk_test_alert_rule_test"
            baseTableSchemaName="clinlims" baseTableName="test_alert_rule" baseColumnNames="test_id"
            referencedTableSchemaName="clinlims" referencedTableName="test" referencedColumnNames="id"/>
        <addForeignKeyConstraint
            constraintName="fk_test_alert_rule_role"
            baseTableSchemaName="clinlims" baseTableName="test_alert_rule" baseColumnNames="notify_role_id"
            referencedTableSchemaName="clinlims" referencedTableName="system_role" referencedColumnNames="id"/>

        <createIndex schemaName="clinlims" tableName="test_alert_rule" indexName="idx_test_alert_rule_test">
            <column name="test_id"/>
        </createIndex>

        <rollback>
            <dropTable schemaName="clinlims" tableName="test_alert_rule"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
