<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet author="mozzy11" id="create-patient-id-document">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="patient_id_document" schemaName="clinlims"/>
            </not>
        </preConditions>
        <comment>Create patient ID document table for scanned identification cards</comment>
        <createSequence incrementBy="1" schemaName="clinlims" sequenceName="patient_id_document_seq" startValue="1" />

        <createTable tableName="patient_id_document">
            <column name="id" type="INTEGER" valueSequenceNext="patient_id_document_seq">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="patient_id" type="VARCHAR">
                <constraints nullable="false"/>
            </column>
            <column name="document_data" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="thumbnail_data" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="document_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="document_category" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="VARCHAR(255)"/>
            <column name="deleted" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="last_updated" type="datetime"/>
        </createTable>

        <createIndex tableName="patient_id_document" indexName="idx_patient_id_document_patient_id">
            <column name="patient_id"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
