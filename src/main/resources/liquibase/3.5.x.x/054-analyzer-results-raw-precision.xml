<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <!-- ================================================================== -->
    <!-- LIS-188 — analyzer results: keep the machine-sent numeric precision -->
    <!--                                                                    -->
    <!-- Symptom: analyzer results display (and, on technical accept,          -->
    <!-- PERSIST) as whole numbers / fixed decimals instead of the value the   -->
    <!-- instrument sent (e.g. ALT 45.7 -> 46).                                -->
    <!--                                                                    -->
    <!-- Cause: rounding is driven per test by test_result.significant_digits. -->
    <!-- AnalyzerResultsController.getRoundedToSignificantDigits() formats the  -->
    <!-- raw wire value with String.format("%.<sig>f", value)                   -->
    <!-- (StringUtil.doubleWithSignificantDigits), and Java %f rounds HALF_UP:  -->
    <!--   0  = whole number      (45.7 -> "46")                              -->
    <!--   N  = N decimal places  (rounds/pads to N)                          -->
    <!--  -1  = return the raw value verbatim  (what we want)                  -->
    <!-- The rounded string is then what AnalyzerResultsAcceptServiceImpl       -->
    <!-- .createNewResult() stores, so precision is lost permanently on accept. -->
    <!-- ResultServiceImpl's display formatters treat the same field the same.  -->
    <!--                                                                    -->
    <!-- Fix: set significant_digits = -1 (raw) for every NUMERIC test result   -->
    <!-- of a test mapped to an analyzer (test_id in analyzer_test_map). The    -->
    <!-- affected rows are OpenELIS demo-seed tests (GPT/GOT/Glucose/Creatinine -->
    <!-- /Amylase/cholesterol/... and the EDAN CBC % / Abs tests) linked to the -->
    <!-- Seamaty SD1 / EDAN analyzers by seeds 049/050/052/053. Because this    -->
    <!-- runs AFTER those map seeds it is durable: it corrects the live bench    -->
    <!-- DB and every fresh DB alike (mirrors the 052/053 pattern — idempotent, -->
    <!-- no context attr so it reaches the integration-test harness).           -->
    <!--                                                                    -->
    <!-- Scope note: only NUMERIC (tst_rslt_type = 'N') analyzer-mapped results  -->
    <!-- are touched; dictionary / alpha results have no significant_digits      -->
    <!-- rounding. Manual (non-analyzer) tests are deliberately left untouched.  -->
    <!-- ================================================================== -->

    <changeSet id="lis188-001-analyzer-numeric-results-raw-precision" author="labsolution">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists schemaName="clinlims" tableName="test_result"/>
                <tableExists schemaName="clinlims" tableName="analyzer_test_map"/>
            </and>
        </preConditions>
        <comment>Set significant_digits = -1 (raw, no rounding) for numeric test results of analyzer-mapped tests, so accepted analyzer results keep the precision the instrument sent. Idempotent: the IS DISTINCT FROM -1 guard makes a re-apply a no-op.</comment>
        <sql>
            UPDATE clinlims.test_result
            SET significant_digits = -1
            WHERE tst_rslt_type = 'N'
              AND significant_digits IS DISTINCT FROM -1
              AND test_id IN (
                    SELECT DISTINCT test_id
                    FROM clinlims.analyzer_test_map
                    WHERE test_id IS NOT NULL);
        </sql>
        <rollback>
            <!-- No-op by design (the safe direction, mirroring 053 cs2's philosophy).
                 The prior significant_digits (0/1/2) were OpenELIS demo-seed defaults,
                 not deliberate lab configuration, and restoring them would re-introduce
                 the exact data-loss defect this changeset fixes (rounding the machine's
                 value). Widening to raw precision (-1) is never lossy, so the safe
                 inverse is to leave it raw; a re-apply is idempotent via the WHERE guard.
                 A lab that wants a specific display precision for one test can set it in
                 the Test Catalog admin screen. -->
        </rollback>
    </changeSet>

</databaseChangeLog>
